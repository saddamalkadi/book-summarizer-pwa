{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sadam-key",
  "main": "keys-worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "OPENROUTER_TITLE": "AI Workspace Studio",
    "OPENROUTER_REFERER": "https://dash.cloudflare.com",
    "APP_BRAND_NAME": "AI Workspace Studio",
    "APP_DEVELOPER_NAME": "صدام القاضي",
    "APP_UPGRADE_EMAIL": "tntntt830@gmail.com",
    "APP_ADMIN_EMAIL": "tntntt830@gmail.com",
    "AUTH_REQUIRE_LOGIN": "true",
    "GOOGLE_CLIENT_ID_WEB": ""
  }
}
