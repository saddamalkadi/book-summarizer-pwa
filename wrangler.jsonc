{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "book-summarizer-pwa-convert",
  "main": "keys-worker.js",
  "compatibility_date": "2025-09-27",
  "routes": [
    {
      "pattern": "api.saddamalkadi.com",
      "custom_domain": true,
      "zone_name": "saddamalkadi.com"
    }
  ],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "USER_DATA",
      "id": "49d87e2d4989452fb3c680ad024ae5b7"
    }
  ],
  "services": [
    {
      "binding": "CONVERT",
      "service": "sadam-convert"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "WORKER_PUBLIC_NAME": "sadam-key",
    "OPENROUTER_TITLE": "AI Workspace Studio",
    "OPENROUTER_REFERER": "https://app.saddamalkadi.com/",
    "APP_BRAND_NAME": "AI Workspace Studio",
    "APP_DEVELOPER_NAME": "صدام القاضي",
    "APP_UPGRADE_EMAIL": "tntntt830@gmail.com",
    "APP_ADMIN_EMAIL": "tntntt830@gmail.com",
    "AUTH_REQUIRE_LOGIN": "true",
    "GOOGLE_CLIENT_ID_WEB": "320883717933-d8p8877if6u4udo9tfvhbq1en2ps486m.apps.googleusercontent.com"
  }
}
