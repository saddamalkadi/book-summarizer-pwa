{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sadam-convert",
  "main": "convert-worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "vars": {
    "OPENROUTER_REFERER": "https://sadam-key.tntntt830.workers.dev/",
    "OPENROUTER_TITLE": "AI Workspace Studio Convert",
    "MAX_PDF_PAGES": "40",
    "MAX_FILE_MB": "15",
    "STRICT_PDF_PAGES": "18",
    "STRICT_FILE_MB": "8",
    "OPEN_PDF_PAGES": "60",
    "OPEN_FILE_MB": "25",
    "MAX_OCR_IMAGE_MB": "8"
  }
}
