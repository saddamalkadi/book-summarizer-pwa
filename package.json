{
  "name": "book-summarizer-pwa",
  "version": "9.6.10",
  "private": true,
  "description": "AI Workspace Studio - static Arabic AI workspace with Capacitor wrappers for Android and iPhone.",
  "scripts": {
    "check:app": "node --check app.js && node scripts/verify-app-js-symbols.mjs",
    "sync:web": "node scripts/sync-web.mjs",
    "cap:copy": "npm run sync:web && npx cap copy",
    "cap:sync": "npm run sync:web && npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor-community/text-to-speech": "^6.0.0",
    "@capacitor/app": "^7.1.0",
    "@capacitor/browser": "^7.0.2",
    "@capacitor/core": "^7.4.3",
    "@capacitor/preferences": "^7.0.4",
    "capacitor-native-google-one-tap-signin": "^7.0.3"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "eslint-scope": "^9.1.2",
    "espree": "^11.2.0",
    "globals": "^17.5.0",
    "playwright": "^1.59.1"
  }
}
